# Kamal pulls these at deploy time. Copy this file to .kamal/secrets and
# populate. NEVER commit .kamal/secrets - it is gitignored.
#
# Local source order (Kamal evaluates left-to-right): your shell env, then
# this file. So you can `export DB_PASSWORD=...` before `kamal deploy` and
# omit it here.

# --- Container registry (push images, pull on the VM) ---
KAMAL_REGISTRY_PASSWORD=$(cat ~/.config/gh/ghcr_token)

# --- Laravel core ---
APP_KEY=base64:REPLACE_WITH_php-artisan-key:generate
DB_PASSWORD=replace_with_strong_password
POSTGRES_PASSWORD=$DB_PASSWORD

# --- Reverb (WebSocket app) ---
REVERB_APP_ID=replace
REVERB_APP_KEY=replace
REVERB_APP_SECRET=replace
VITE_REVERB_APP_KEY=$REVERB_APP_KEY

# --- Twitch OAuth + EventSub ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=

# --- Twitch bot (separate Twitch dev app) ---
TWITCHBOT_CLIENT_ID=
TWITCHBOT_CLIENT_SECRET=
TWITCHBOT_LISTENER_SECRET=

# --- StreamLabs ---
STREAMLABS_CLIENT_ID=
STREAMLABS_CLIENT_SECRET=
STREAMLABS_LISTENER_SECRET=

# --- StreamElements ---
STREAMELEMENTS_LISTENER_SECRET=

# --- Fourthwall ---
# AUTH_URL is the shop-scoped URL Fourthwall gives you; it already embeds the
# client id in the path and ends with `?redirect_uri=` for the app to append.
# FW_HMAC is the app-level HMAC Fourthwall shows once on app creation - it is
# used to verify every inbound webhook (X-Fourthwall-Hmac-Apps-Sha256 header).
FW_CLIENT_ID=
FW_CLIENT_SECRET=
FW_AUTH_URL=
FW_REDIRECT_URL=
FW_HMAC=

# --- Cloudinary (single URL form) ---
CLOUDINARY_URL=

# --- Freesound (static API key for search/sound-info; OAuth client unused) ---
# Grab this from your app's page on https://freesound.org/apiv2/apply/ - it is
# a separate field from Client ID / Client Secret. Used by FreesoundClient with
# `Authorization: Token <key>` for read-only endpoints; we never download
# originals so no OAuth is needed.
FREESOUND_API_KEY=

# --- Misc ---
INTEGRATION_SUGGESTION_WEBHOOK_URL=
SIGNUP_NOTIFICATION_EMAIL=
DEPLOY_WEBHOOK_SECRET=
